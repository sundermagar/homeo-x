{
  "name": "@mmc/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir src/domains",
    "test:integration": "vitest run --dir src/__tests__",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mmc/types": "workspace:*",
    "@mmc/database": "workspace:*",
    "@mmc/validation": "workspace:*",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "helmet": "^8.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^8.3.0",
    "compression": "^1.8.0",
    "ioredis": "^5.10.0",
    "@upstash/redis": "^1.37.0",
    "@google/generative-ai": "^0.24.0",
    "zod": "^3.24.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/compression": "^1.7.0"
  }
}
