# ─── Server ───
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── JWT ───
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ─── PostgreSQL ───
DATABASE_URL=postgresql://postgres:password@localhost:5432/homeo_x
# Schema-per-tenant: each clinic gets its own schema within this database

# ─── Redis ───
REDIS_URL=redis://localhost:6379
# OR Upstash (serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── AI Providers ───
GEMINI_API_KEY=key1,key2
GROQ_API_KEY=key1,key2

# ─── Transcription ───
DEEPGRAM_API_KEY=

# ─── Video Calls ───
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Payments ───
RAZORPAY_KEY=
RAZORPAY_SECRET=

# ─── Communications ───
WHATSAPP_API_URL=
WHATSAPP_SECRET=
SMS_API_URL=
SMS_API_USER=
SMS_API_PASSWORD=

# ─── Email ───
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# ─── CORS ───
CORS_ORIGINS=http://localhost:5173
