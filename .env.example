# ─── App Configuration ──────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# ─── Authentication (JWT) ───────────────────────────────────────
# Use a strong random string (e.g., `openssl rand -base64 32`)
JWT_SECRET=your-production-secret-key
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-production-refresh-key
JWT_REFRESH_EXPIRES_IN=7d

# ─── Database ───────────────────────────────────────────────────
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:password@localhost:5432/homeo_x

# ─── Redis (Caching & Sessions) ───────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Mailer (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-specific-password
MAIL_ENCRYPTION=tls

# ─── Secure Payments (Razorpay) ──────────────────────────────
RAZORPAY_KEY=your-razorpay-key
RAZORPAY_SECRET=your-razorpay-secret

# ─── WhatsApp Integration (BulkShooters) ──────────────────────
WHATSAPP_SECRET=your-whatsapp-secret
WHATSAPP_API_URL=https://bulkshooters.in/api/send/whatsapp
WHATSAPP_ACCOUNT_DEFAULT=your-default-instance-id

# ─── SMS Gateway ───────────────────────────────────────────────
SMS_API_URL=https://websms.bulksmsprime.com/vendorsms/pushsms.aspx
SMS_API_USER=your-sms-username
SMS_API_PASSWORD=your-sms-password
SMS_SENDER_ID=your-sender-id

# ─── AI Providers (Intelligence) ──────────────────────────────
# Primary AI (GPT-4 / Gemini)
AI_ENDPOINT=
AI_API_KEY=
AI_DEPLOYMENT=gpt-4o-mini
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key

# ─── Audio & Transcription (Deepgram) ─────────────────────────
DEEPGRAM_API_KEY=your-deepgram-key

# ─── Real-time Video (LiveKit) ───────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-key
LIVEKIT_API_SECRET=your-livekit-secret

# ─── Networking & CORS ────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=localhost:5173
