{
  "name": "kreed-health",
  "private": true,
  "scripts": {
    "build": "npx turbo run build",
    "start:api": "pnpm --filter=@mmc/database run migrate:tenants && pnpm --filter=@mmc/database run db:migrate:settings && pnpm --filter=@mmc/database run db:seed && pnpm --filter=@mmc/api start",
    "start:web": "npx serve -s apps/web/dist -p $PORT",
    "dev": "npx turbo run dev",
    "dev:api": "npx turbo run dev --filter=@mmc/api",
    "dev:web": "npx turbo run dev --filter=@mmc/web",
    "lint": "npx turbo run lint",
    "test": "npx turbo run test",
    "test:unit": "npx turbo run test:unit",
    "test:integration": "npx turbo run test:integration",
    "typecheck": "npx turbo run typecheck",
    "db:generate": "npx turbo run db:generate --filter=@mmc/database",
    "db:migrate": "npx turbo run db:migrate --filter=@mmc/database",
    "db:seed": "npx turbo run db:seed --filter=@mmc/database",
    "clean": "npx turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
