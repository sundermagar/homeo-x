{
  "name": "@mmc/types",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./domains/*": { "import": "./dist/domains/*.js", "types": "./dist/domains/*.d.ts" },
    "./api/*": { "import": "./dist/api/*.js", "types": "./dist/api/*.d.ts" },
    "./events/*": { "import": "./dist/events/*.js", "types": "./dist/events/*.d.ts" }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
