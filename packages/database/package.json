{
  "name": "@mmc/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:generate:legacy": "drizzle-kit generate --config=drizzle.legacy.config.ts",
    "db:migrate:legacy": "drizzle-kit migrate --config=drizzle.legacy.config.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seeds/run.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@mmc/types": "workspace:*",
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
